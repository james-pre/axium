{
	"compilerOptions": {
		"verbatimModuleSyntax": true,
		"isolatedModules": true,
		// DOM is for types only!
		"lib": ["ESNext", "DOM", "DOM.Iterable"],
		"moduleResolution": "NodeNext",
		"module": "NodeNext",
		"target": "ES2023",
		"strict": true,
		"resolveJsonModule": true,
		"importJsonAsConst": true,
		"declaration": true,
		"typeRoots": ["./node_modules/@types", "./types"],
		"types": ["node", "commander"],
		"paths": {
			"@axium/calendar": ["./packages/calendar/*"],
			"@axium/client": ["./packages/client/*"],
			"@axium/contacts": ["./packages/contacts/*"],
			"@axium/core": ["./packages/core/*"],
			"@axium/notes": ["./packages/notes/*"],
			"@axium/server": ["./packages/server/*"],
			"@axium/storage": ["./packages/storage/*"],
			"@axium/sysadmin": ["./packages/sysadmin/*"],
			"@axium/tasks": ["./packages/tasks/*"]
		},
		"skipLibCheck": true
	},
	"exclude": ["node_modules"],
	"files": [],
	"references": [
		{ "path": "./packages/calendar" },
		{ "path": "./packages/client" },
		{ "path": "./packages/contacts" },
		{ "path": "./packages/core" },
		{ "path": "./packages/notes" },
		{ "path": "./packages/server" },
		{ "path": "./packages/storage" },
		{ "path": "./packages/sysadmin" },
		{ "path": "./packages/tasks" }
	]
}
