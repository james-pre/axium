{
	"name": "@axium/server",
	"version": "0.44.3",
	"author": "James Prevett <axium@jamespre.dev>",
	"funding": {
		"type": "individual",
		"url": "https://github.com/sponsors/james-pre"
	},
	"license": "LGPL-3.0-or-later",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/james-pre/axium.git"
	},
	"homepage": "https://github.com/james-pre/axium#readme",
	"bugs": {
		"url": "https://github.com/james-pre/axium/issues"
	},
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": "./dist/index.js",
		"./cli": "./dist/cli/index.js",
		"./database": "./dist/db/index.js",
		"./*": "./dist/*.js",
		"./$hooks": "./web/hooks.server.ts",
		"./$routes": "./routes",
		"./$template": "./web/template.html"
	},
	"files": [
		"assets",
		"dist",
		"patches",
		"routes",
		"schemas",
		"web.tsconfig.json",
		"template.html",
		"axium.service"
	],
	"bin": {
		"axium": "dist/main.js"
	},
	"scripts": {
		"build": "tsc",
		"build:schemas": "mkdir -p schemas && node dist/main.js config schema -j > schemas/config.json && node dist/main.js db json-schema -j > schemas/db.json",
		"clean": "rm -rf build .svelte-kit node_modules/{.vite,.vite-temp}",
		"postinstall": "node patches/patch.js"
	},
	"peerDependencies": {
		"@axium/client": ">=0.21.0",
		"@axium/core": ">=0.28.0",
		"@simplewebauthn/browser": "^13.3.0",
		"@sveltejs/adapter-node": "^5.2.12",
		"@sveltejs/kit": "2.56.1",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"kysely": "^0.28.0",
		"svelte": "^5.36.0",
		"utilium": "^3.0.0",
		"zod": "^4.0.5"
	},
	"dependencies": {
		"@simplewebauthn/server": "^13.1.1",
		"@types/pg": "^8.11.11",
		"commander": "^14.0.0",
		"cookie_v1": "npm:cookie@^1.0.2",
		"ioium": "^1.0.0",
		"logzen": "^0.7.0",
		"patch-package": "^8.0.1",
		"pg": "^8.14.1",
		"sharp": "^0.34.5",
		"vite": "^8.0.5"
	},
	"optionalDependencies": {
		"ua-parser-js": "^2.0.9"
	}
}
