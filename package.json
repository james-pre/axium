{
	"name": "@axium/root",
	"version": "0.0.0",
	"private": true,
	"description": "A self-hosted productivity platform",
	"author": "James Prevett <axium@jamespre.dev>",
	"funding": {
		"type": "individual",
		"url": "https://github.com/sponsors/james-pre"
	},
	"license": "LGPL-3.0-or-later",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/james-pre/axium.git"
	},
	"homepage": "https://github.com/james-pre/axium#readme",
	"bugs": {
		"url": "https://github.com/james-pre/axium/issues"
	},
	"main": "dist/index.js",
	"scripts": {
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"lint": "eslint packages/*/src",
		"build:schemas": "(cd packages/server && npm run build:schemas)",
		"build": "tsc -b && for pkg in server storage calendar contacts notes tasks; do (cd packages/$pkg && axium build); done",
		"watch": "tsc -b -w",
		"clean": "rm -rf packages/*/tsconfig.tsbuildinfo packages/*/dist packages/server/node_modules/{.vite,.vite-temp} packages/server/build",
		"postinstall": "patch-package",
		"wc-source": "wc -l $(git ls-files | grep -v package-lock.json | grep -v packages/client/assets/icons | grep -v LICENSE.md) | sort -h"
	},
	"workspaces": [
		"packages/*"
	],
	"keywords": [],
	"type": "module",
	"devDependencies": {
		"@axium/calendar": "workspace:*",
		"@axium/client": "workspace:*",
		"@axium/contacts": "workspace:*",
		"@axium/core": "workspace:*",
		"@axium/notes": "workspace:*",
		"@axium/server": "workspace:*",
		"@axium/storage": "workspace:*",
		"@axium/tasks": "workspace:*",
		"@commander-js/extra-typings": "^15.0.0",
		"@eslint/js": "^10.0.1",
		"@types/node": "^25.5.0",
		"eslint": "^10.1.0",
		"globals": "^17.4.0",
		"patch-package": "^8.0.1",
		"prettier": "^3.5.1",
		"prettier-plugin-svelte": "^4.1.0",
		"svelte": "^5.55.3",
		"svelte-language-server": "^0.18.0",
		"tsx": "^4.19.3",
		"typedoc": "^0.28.18",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.58.0"
	},
	"prettier": {
		"plugins": [
			"prettier-plugin-svelte"
		],
		"singleQuote": true,
		"useTabs": true,
		"trailingComma": "es5",
		"tabWidth": 4,
		"printWidth": 140,
		"arrowParens": "avoid"
	},
	"allowScripts": {
		"sharp": true,
		"esbuild": true
	}
}
